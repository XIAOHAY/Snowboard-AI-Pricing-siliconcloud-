# ============================================================
# Streamlit Secrets 模板（结构参考，可安全提交）
# ⚠️ 真实密钥永远不要提交！真实内容只填到两个地方：
#    线上：Streamlit Cloud → App settings → Secrets
#    本地：复制本文件为 .streamlit/secrets.toml（已 gitignore）或写进 .env
# ============================================================

# === API 凭证（必填）===
DASHSCOPE_API_KEY = "在此填入你的硅基流动 API Key"

# === 接入点（可选，默认硅基流动）===
LLM_BASE_URL = "https://api.siliconflow.cn/v1"

# === 模型 ID（可选，改模型只改这里，无需动代码、无需改业务逻辑）===
VL_MODEL     = "Qwen/Qwen2-VL-72B-Instruct"     # 视觉鉴定（想升级可改 Qwen/Qwen2.5-VL-72B-Instruct）
REVIEW_MODEL = "Qwen/Qwen2.5-72B-Instruct"      # 专家点评
CHAT_MODEL   = "Qwen/Qwen2.5-72B-Instruct"      # 追问对话
AGENT_MODEL  = "Qwen/Qwen2.5-72B-Instruct"      # Agent 决策
